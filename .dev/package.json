{
  "name": "openagent-terminal-tools",
  "version": "1.0.0",
  "description": "Development and testing tools for OpenAgent Terminal",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node --test dist/**/*.test.js || true",
    "lint": "bash -lc 'cd .. && eslint -c .dev/eslint.config.js src/**/*.ts'",
    "lint:fix": "bash -lc 'cd .. && eslint -c .dev/eslint.config.js src/**/*.ts --fix'",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist/",
    "dev": "npm run build:watch",
    "ci": "npm run type-check && npm run lint && npm run build && npm run test",
    "fuzz-ci": "node ci/fuzz.mjs || true"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "OpenAgent Terminal Contributors",
  "license": "Apache-2.0"
}
