# Git LFS configuration for large/binary artifacts

# Vector/raster assets and app icons
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.icns filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text

# PostScript/PDF and other heavy docs
*.ps filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text

# Test reference snapshots (very large JSON fixtures)
openagent-terminal-core/tests/ref/**/*.json filter=lfs diff=lfs merge=lfs -text

# Optional: any root-level large sample data named exactly 'json' (if retained)
/json filter=lfs diff=lfs merge=lfs -text
