# Example environment variables for OpenAgent Terminal

# IMPORTANT
# - Do NOT commit real secrets. This file is for documentation only.
# - Prefer a secret manager (e.g., 1Password, Bitwarden, AWS Secrets Manager, gnome-keyring) or
#   export variables in your shell startup files locally.
# - Apps should read from environment variables at runtime; never hardcode credentials.

# --- AI Providers ---
# OpenAI
OPENAI_API_KEY=
# Anthropiс
ANTHROPIC_API_KEY=
# OpenRouter (proxy for many models)
OPENROUTER_API_KEY=
# Local AI (Ollama). Default is http://127.0.0.1:11434
# Prefer provider-native envs
OLLAMA_HOST=http://127.0.0.1:11434
# Optional convenience for model selection
OLLAMA_MODEL=
# Alternate OPENAGENT_* mapping (if configured via ai.providers.ollama in config)
# OPENAGENT_OLLAMA_ENDPOINT=
# OPENAGENT_OLLAMA_MODEL=
# --- OpenAgent Terminal settings ---
# Throttle AI streaming redraws (ms). Typical: 8, 16 (default), 32
OPENAGENT_AI_STREAM_REDRAW_MS=16
# AI logging verbosity: "off" | "summary" | "verbose"
OPENAGENT_AI_LOG_VERBOSITY=summary
# Optional Prometheus metrics port
OPENAGENT_PROM_PORT=9898

# --- CLI/Notebook paths (override defaults if needed) ---
# XDG-style overrides (Linux shown here); leave blank to use defaults
XDG_CONFIG_HOME=
XDG_DATA_HOME=

# --- Security & Privacy ---
# Never commit secrets. If you need to persist locally, consider a manager and inject via env at runtime.
# Example: export OPENAI_API_KEY=$(secret_manager --name openai/prod)
